{
  "family": "jbr-coins-api",
  "executionRoleArn": "arn:aws:iam::261219435789:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::261219435789:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "coins-api-server",
      "image": "jbr-coins-api:latest",
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000
        }
      ]
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512"
}
